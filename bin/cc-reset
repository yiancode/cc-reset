#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/common.sh
source "$ROOT_DIR/lib/common.sh"

ccr::usage() {
  cat <<'EOF'
cc-reset - Claude Code VPS bootstrap helper

Usage:
  cc-reset <command> [options]

Commands:
  install       Install system deps, Node 20 (dnf), Claude Code (global npm)
  doctor        Check current environment status
  login         Start manual OAuth helper flow and persist Claude credentials
  quickstart    Print the canonical git-only bootstrap one-liner
  repo-init     Initialize git repo and optionally configure remote
  version       Print tool version
  help          Show this help

Examples:
  ./bin/cc-reset install
  ./bin/cc-reset install --dry-run
  ./bin/cc-reset doctor
  ./bin/cc-reset login
  ./bin/cc-reset login --print-url
  ./bin/cc-reset quickstart
  ./bin/cc-reset repo-init --remote https://github.com/yiancode/cc-reset.git
EOF
}

ccr::cmd_install() {
  local dry_run=0
  local with_clipboard=1
  while (($#)); do
    case "$1" in
      --dry-run) dry_run=1 ;;
      --no-clipboard) with_clipboard=0 ;;
      -h|--help)
        cat <<'EOF'
Usage: cc-reset install [--dry-run] [--no-clipboard]

Installs:
  - required yum/dnf system packages (git, curl, wget, gcc-c++, make, tar)
  - Node (default major 20, override with CCR_NODE_MAJOR=18) from distro
    package (nodejs<M> + nodejs<M>-npm), symlinked to /usr/local/bin/{node,npm,npx}
  - latest @anthropic-ai/claude-code via sudo npm install -g
  - After install, runs a PTY smoke test: if claude can't actually start
    the TUI under the requested major (a known issue on some OpenCloudOS
    kernels with node 20), automatically falls back to
    CCR_NODE_FALLBACK_MAJOR (default 18) and retries. Set
    CCR_NODE_FALLBACK_MAJOR="" to disable the fallback.

Side-effects:
  - Strips any legacy nvm shell-init block left over by v0.1/v0.2
  - Removes /usr/local/bin/{node,npm,npx,claude} symlinks that point into
    a legacy ~/.nvm tree (those stubs shadow the system install and break
    claude for every user on the host)
  - ~/.nvm itself is NOT auto-removed; cc-reset warns if it is still present
  - Makes claude usable by every user on the host, not just the invoking one
EOF
        return 0
        ;;
      *) ccr::die "Unknown install flag: $1" ;;
    esac
    shift
  done

  ccr::require_linux_or_dry_run "$dry_run"
  ccr::ensure_state_dirs
  ccr::info "cc-reset install is idempotent; safe to re-run if interrupted."
  ccr::install_system_packages "$dry_run"
  if [[ "$with_clipboard" -eq 1 ]]; then
    ccr::ensure_linux_clipboard_tool "$dry_run" || true
  fi
  # Strip any legacy ~/.bashrc nvm block left by v0.1/v0.2 upgrades.
  ccr::ensure_shell_init
  # Remove dangling /usr/local/bin/{node,npm,npx,claude} stubs that point into
  # an old ~/.nvm tree — otherwise they shadow the system install below.
  ccr::purge_legacy_nvm_binstubs "$dry_run"
  # Install node + claude, smoke-test, fall back to CCR_NODE_FALLBACK_MAJOR
  # if the requested major can't actually run the TUI on this host.
  ccr::install_node_and_claude_with_fallback "$dry_run" \
    || ccr::die "Claude Code could not be installed on any attempted Node major. Set CCR_NODE_MAJOR / CCR_NODE_FALLBACK_MAJOR to override."
  # Shell command hash may still cache the old paths within the invoking
  # shell; tell the user so the next `claude` resolves to the new binary.
  if [[ "$dry_run" -ne 1 ]]; then
    ccr::info "If 'claude' in your current shell still errors, run: hash -r"
  fi

  local git_version=""
  local node_version=""
  local npm_version=""
  local claude_version=""
  ccr::has_cmd git && git_version="$(git --version | awk '{print $3}')"
  ccr::has_cmd node && node_version="$(node -v)"
  ccr::has_cmd npm && npm_version="$(npm -v)"
  ccr::has_cmd claude && claude_version="$(claude --version)"

  if [[ "$dry_run" -eq 1 ]]; then
    ccr::render_install_card "$git_version" "$node_version" "$npm_version" "$claude_version" "dry-run"
    return 0
  fi

  ccr::render_install_card "$git_version" "$node_version" "$npm_version" "$claude_version"
}

ccr::cmd_doctor() {
  local json=0
  while (($#)); do
    case "$1" in
      --json) json=1 ;;
      -h|--help)
        cat <<'EOF'
Usage: cc-reset doctor [--json]

Inspect OS, package manager, nvm, Node, npm, Claude Code, and auth files.
EOF
        return 0
        ;;
      *) ccr::die "Unknown doctor flag: $1" ;;
    esac
    shift
  done

  ccr::doctor "$json"
}

ccr::cmd_login() {
  local mode="interactive"
  local callback_url=""
  local code_state=""
  local email=""
  local force=0
  local install_clipboard=1
  local -a start_cmd

  while (($#)); do
    case "$1" in
      --print-url) mode="print-url" ;;
      --callback-url)
        shift
        callback_url="${1:-}"
        [[ -n "$callback_url" ]] || ccr::die "--callback-url requires a value"
        mode="callback"
        ;;
      --code-state)
        shift
        code_state="${1:-}"
        [[ -n "$code_state" ]] || ccr::die "--code-state requires a value"
        mode="code-state"
        ;;
      --email)
        shift
        email="${1:-}"
        [[ -n "$email" ]] || ccr::die "--email requires a value"
        # Minimal sanity check — OAuth uses this as login_hint only, but
        # catching obvious typos here beats a confusing upstream error.
        [[ "$email" == *@*.* ]] || ccr::die "--email does not look like an email address: $email"
        ;;
      --force)
        force=1
        ;;
      --no-clipboard)
        install_clipboard=0
        ;;
      -h|--help)
        cat <<'EOF'
Usage: cc-reset login [--print-url] [--callback-url <url>] [--code-state <code#state>] [--email <email>] [--force] [--no-clipboard]

Start the manual Claude subscription OAuth flow. By default:
  1. Generates the login URL
  2. Prints and tries to copy it
  3. Waits for you to paste the final callback URL (or code#state)
  4. Exchanges the code and writes Claude's native credentials (or env.sh for API key mode)
EOF
        return 0
        ;;
      *)
        ccr::die "Unknown login flag: $1"
        ;;
    esac
    shift
  done

  ccr::require_node
  if [[ "$install_clipboard" -eq 1 ]]; then
    ccr::ensure_linux_clipboard_tool 0 || true
  fi

  if [[ "$force" -ne 1 ]] && ccr::is_authenticated; then
    printf '=============================================\n'
    printf ' cc-reset login\n'
    printf '=============================================\n'
    ccr::status_line "[PASS]" "Authentication" "Existing Claude authentication detected"
    ccr::print_auth_summary
    ccr::status_line "[INFO]" "Next action" "Use './bin/cc-reset login --force' to re-authenticate."
    printf '=============================================\n'
    return 0
  fi

  local start_json auth_url
  start_cmd=(node "$ROOT_DIR/lib/oauth-helper.mjs" start --json)
  if [[ -n "$email" ]]; then
    start_cmd+=(--email "$email")
  fi
  start_json="$("${start_cmd[@]}")"
  auth_url="$(printf '%s' "$start_json" | node -e 'process.stdin.on("data",d=>{const x=JSON.parse(String(d)); process.stdout.write(x.authUrl);})')"
  ccr::info "Open this URL in your local browser to sign in:"
  printf '%s\n' "$auth_url"
  ccr::copy_to_clipboard "$auth_url" || true

  case "$mode" in
    print-url)
      return 0
      ;;
    callback)
      ccr::complete_login_from_callback "$callback_url"
      ;;
    code-state)
      ccr::complete_login_from_code_state "$code_state"
      ;;
    interactive)
      printf '\nPaste the final callback URL (or code#state), then press Enter:\n> '
      local user_input=""
      IFS= read -r user_input
      [[ -n "$user_input" ]] || ccr::die "No callback input provided."
      if [[ "$user_input" == http* ]]; then
        ccr::complete_login_from_callback "$user_input"
      else
        ccr::complete_login_from_code_state "$user_input"
      fi
      ;;
  esac
}

ccr::complete_login_from_callback() {
  local callback_url="$1"
  local login_result
  login_result="$(node "$ROOT_DIR/lib/oauth-helper.mjs" complete --callback-url "$callback_url")"
  printf '%s\n' "$login_result"
  ccr::post_login_message "$login_result"
}

ccr::complete_login_from_code_state() {
  local code_state="$1"
  local login_result
  login_result="$(node "$ROOT_DIR/lib/oauth-helper.mjs" complete --code-state "$code_state")"
  printf '%s\n' "$login_result"
  ccr::post_login_message "$login_result"
}

ccr::post_login_message() {
  local login_result="${1:-}"
  local mode=""
  local env_file=""
  local credentials_file=""
  local had_stale_oauth_env=0

  if [[ -n "$login_result" ]]; then
    mode="$(printf '%s' "$login_result" | node -e 'process.stdin.on("data",d=>{const x=JSON.parse(String(d)); process.stdout.write(x.mode || "");})')"
    env_file="$(printf '%s' "$login_result" | node -e 'process.stdin.on("data",d=>{const x=JSON.parse(String(d)); process.stdout.write(x.envFile || "");})')"
    credentials_file="$(printf '%s' "$login_result" | node -e 'process.stdin.on("data",d=>{const x=JSON.parse(String(d)); process.stdout.write(x.credentialsFile || "");})')"
  fi

  [[ -n "$env_file" ]] || env_file="$(ccr::env_file)"
  ccr::info "Claude onboarding config has also been updated to avoid the first-run login picker."
  if [[ "$mode" == "claude-subscription" ]]; then
    ccr::oauth_env_present_in_shell && had_stale_oauth_env=1
    ccr::clear_stale_oauth_env
    ccr::info "Claude subscription credentials written to: ${credentials_file:-$(ccr::claude_credentials_file)}"
    ccr::info "No shell sourcing is required for subscription login."
    if [[ "$had_stale_oauth_env" -eq 1 ]]; then
      ccr::warn "This shell had legacy CLAUDE_CODE_OAUTH_* variables loaded. They were unset for the current session; start a new shell if they were exported elsewhere."
    fi
  else
    ccr::info "API key login material written to: $env_file"
    ccr::info "Run the following in your shell:"
    printf 'source %q\n' "$env_file"
    if [[ -f "$env_file" ]]; then
      # shellcheck disable=SC1090
      source "$env_file"
    fi
  fi

  if command -v claude >/dev/null 2>&1; then
    ccr::info "Current Claude auth status:"
    claude auth status --text || true
  fi
}

ccr::cmd_repo_init() {
  local remote=""
  while (($#)); do
    case "$1" in
      --remote)
        shift
        remote="${1:-}"
        [[ -n "$remote" ]] || ccr::die "--remote requires a value"
        ;;
      -h|--help)
        cat <<'EOF'
Usage: cc-reset repo-init [--remote <url>]

Initialize a git repository if needed and configure origin if provided.
EOF
        return 0
        ;;
      *) ccr::die "Unknown repo-init flag: $1" ;;
    esac
    shift
  done

  ccr::repo_init "$remote"
}

ccr::cmd_quickstart() {
  "$ROOT_DIR/scripts/print-quickstart.sh" "$@"
}

main() {
  local command="${1:-help}"
  shift || true

  case "$command" in
    install) ccr::cmd_install "$@" ;;
    doctor) ccr::cmd_doctor "$@" ;;
    login) ccr::cmd_login "$@" ;;
    quickstart) ccr::cmd_quickstart "$@" ;;
    repo-init) ccr::cmd_repo_init "$@" ;;
    version) echo "$CCR_VERSION" ;;
    help|-h|--help) ccr::usage ;;
    *) ccr::die "Unknown command: $command" ;;
  esac
}

main "$@"
